{
  "name": "ai-media-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev -w @media/api",
    "dev:hermes": "cd apps/hermes && ./scripts/run-dev.sh",
    "dev:worker": "npm run dev -w @media/worker",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
