NODE_ENV=production
PORT=3000

LOG_LEVEL=info
CORS_ORIGIN=*
BODY_LIMIT=10mb

REDIS_URL=redis://redis:6379

DATABASE_URL=postgresql://media:media@postgres:5432/media_platform

PUBLIC_BASE_URL=https://example.com

HERMES_ENV=production
HERMES_HOST=0.0.0.0
HERMES_PORT=8000
HERMES_LOG_LEVEL=info
HERMES_BASE_URL=http://hermes:8000
HERMES_MEMORY_PREFIX=hermes:memory
HERMES_ORCHESTRATION_PREFIX=hermes:orchestration
HERMES_WORKER_STREAM=hermes:worker_commands
HERMES_EVENT_STREAM=hermes:events
HERMES_MEMORY_TTL_SECONDS=0
HERMES_SQLITE_PATH=/data/hermes/hermes-memory.sqlite3
CODEX_BRIDGE_ENABLED=false
CODEX_WORKSPACE_ROOT=/data/codex-workspaces
CODEX_CLI_COMMAND=codex exec
CODEX_TIMEOUT_SECONDS=900
CODEX_MAX_PATCH_BYTES=2000000

TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

COMFYUI_BASE_URL=http://comfyui:8188
COMFYUI_API_KEY=
COMFYUI_TIMEOUT_MS=120000
COMFYUI_POLL_INTERVAL_MS=2000
COMFYUI_MAX_POLL_ATTEMPTS=120

STORAGE_DRIVER=s3
WORKER_ROLE=all
LOCAL_STORAGE_ROOT=/data/media
S3_REGION=us-east-1
S3_BUCKET=media-platform
S3_ENDPOINT=http://storage:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=3600
STORAGE_UPLOAD_RETRIES=3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

NEXTCLOUD_WEBDAV_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_ROOT_FOLDER=/AI Media Platform
NEXTCLOUD_UPLOAD_RETRIES=3
SYNC_CONCURRENCY=2

OPENAI_API_KEY=
REPLICATE_API_TOKEN=
REPLICATE_MODEL_OWNER=
REPLICATE_MODEL_NAME=
REPLICATE_MODEL_VERSION=
REPLICATE_DEPLOYMENT_OWNER=
REPLICATE_DEPLOYMENT_NAME=
REPLICATE_POLL_INTERVAL_MS=5000
REPLICATE_MAX_POLL_ATTEMPTS=240
REPLICATE_CANCEL_AFTER=30m
VIDEO_GENERATION_CONCURRENCY=1

RENDER_CONCURRENCY=2
GENERATION_CONCURRENCY=2
