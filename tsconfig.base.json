{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@media/shared/*": ["packages/shared/src/*"],
      "@media/queue/*": ["packages/queue/src/*"],
      "@media/storage/*": ["packages/storage/src/*"],
      "@media/comfyui-bridge/*": ["packages/comfyui-bridge/src/*"]
    }
  }
}

